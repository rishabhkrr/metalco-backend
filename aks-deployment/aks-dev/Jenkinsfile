pipeline {
  agent any

  environment {
    APP_NAME = 'metalco-backend'
    ACR_LOGIN_SERVER = 'gemba.azurecr.io'
    IMAGE_NAME = "gemba.azurecr.io/metalco-backend"
    RESOURCE_GROUP = 'development'
    AKS_CLUSTER = 'gemba-dev'
  }

  tools {
    jdk 'jdk21'
    maven 'maven_3_9_11'
  }

  stages {

    stage('Checkout Code') {
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: 'aks-dev']],     // ← Your deployment branch
          doGenerateSubmoduleConfigurations: false,
          extensions: [
            [$class: 'CleanBeforeCheckout'],
            [$class: 'CloneOption', shallow: false]
          ],
          userRemoteConfigs: [[
            url: 'https://gitlab.gembaconnect.in/client-projects/metalco/metalco-backend',
            credentialsId: 'gitlab-credentials'
          ]]
        ])
      }
    }

    stage('Determine Image Tag') {
      steps {
        script {
          IMAGE_TAG = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
          echo "IMAGE_TAG = ${IMAGE_TAG}"
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        script {
          sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -t ${IMAGE_NAME}:latest -f aks-deployment/aks-dev/Dockerfile ."
        }
      }
    }

    stage('Push Docker Image to ACR') {
      steps {
        script {
          withCredentials([usernamePassword(
            credentialsId: 'acr-creds',
            usernameVariable: 'ACR_USER',
            passwordVariable: 'ACR_PASS'
          )]) {
            sh "docker login ${ACR_LOGIN_SERVER} -u $ACR_USER -p $ACR_PASS"
            sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
            sh "docker push ${IMAGE_NAME}:latest"
          }
        }
      }
    }

    stage('Deploy to AKS') {
      steps {
        withCredentials([
          string(credentialsId: 'AZURE_CLIENT_ID', variable: 'AZURE_CLIENT_ID'),
          string(credentialsId: 'AZURE_CLIENT_SECRET', variable: 'AZURE_CLIENT_SECRET'),
          string(credentialsId: 'AZURE_TENANT_ID', variable: 'AZURE_TENANT_ID'),
          string(credentialsId: 'AZURE_SUBSCRIPTION_ID', variable: 'AZURE_SUBSCRIPTION_ID')
        ]) {
          script {
            sh '''
              az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID
              az account set --subscription $AZURE_SUBSCRIPTION_ID
              az aks get-credentials --resource-group development --name gemba-dev --overwrite-existing
            '''

            sh 'kubectl get namespace metalco-backend || kubectl create namespace metalco-backend'

            sh 'kubectl apply -f aks-deployment/aks-dev/deployment.yaml -n metalco-backend'

            sh "kubectl set image deployment/metalco-backend-deployment metalco-backend=${IMAGE_NAME}:${IMAGE_TAG} -n metalco-backend"

            sh "kubectl rollout status deployment/metalco-backend-deployment -n metalco-backend"
          }
        }
      }
    }

    stage('Apply Ingress') {
      steps {
        sh 'kubectl apply -f aks-deployment/aks-dev/ingress.yaml -n metalco-backend'
      }
    }

  }
}
